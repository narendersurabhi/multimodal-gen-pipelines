{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/cir.schema.json",
  "title": "Canonical Intermediate Representation",
  "description": "Finalized Phase 2 system-of-record contract for normalized multimodal assets prior to retrieval and generation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "cir_id",
    "asset_id",
    "source_type",
    "ingestion",
    "content",
    "artifacts",
    "provenance",
    "quality_scores",
    "timestamps"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.1.0"
    },
    "cir_id": {
      "type": "string",
      "pattern": "^cir_[A-Za-z0-9_-]+$"
    },
    "asset_id": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "enum": ["text", "document", "image"]
    },
    "tenant_id": {
      "type": "string"
    },
    "request_id": {
      "type": "string"
    },
    "document_type": {
      "type": "string"
    },
    "ingestion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_uri", "mime_type", "checksum_sha256"],
      "properties": {
        "source_uri": { "type": "string" },
        "mime_type": { "type": "string" },
        "checksum_sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "language": { "type": "string" },
        "page_count": { "type": "integer", "minimum": 0 },
        "file_size_bytes": { "type": "integer", "minimum": 0 },
        "ingestion_channel": { "type": "string" }
      }
    },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw_text", "normalized_text", "chunks"],
      "properties": {
        "raw_text": { "type": "string" },
        "normalized_text": { "type": "string" },
        "page_summaries": {
          "type": "array",
          "items": { "$ref": "#/$defs/pageSummary" },
          "default": []
        },
        "chunks": {
          "type": "array",
          "items": { "$ref": "#/$defs/chunk" }
        },
        "tables": {
          "type": "array",
          "items": { "$ref": "#/$defs/table" },
          "default": []
        },
        "figures": {
          "type": "array",
          "items": { "$ref": "#/$defs/figure" },
          "default": []
        },
        "captions": {
          "type": "array",
          "items": { "$ref": "#/$defs/caption" },
          "default": []
        },
        "entities": {
          "type": "array",
          "items": { "$ref": "#/$defs/entity" },
          "default": []
        },
        "safety_labels": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["extraction_bundle_uri", "cir_uri"],
      "properties": {
        "extraction_bundle_uri": { "type": "string" },
        "cir_uri": { "type": "string" },
        "searchable_record_refs": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "derived_artifact_uris": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pipeline_run_id", "processor_versions", "source_artifact_version"],
      "properties": {
        "pipeline_run_id": { "type": "string" },
        "source_artifact_version": { "type": "string" },
        "processor_versions": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "source_system": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "quality_scores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overall_confidence"],
      "properties": {
        "overall_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "ocr_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "caption_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "table_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ingested_at", "processed_at", "materialized_at"],
      "properties": {
        "ingested_at": { "type": "string", "format": "date-time" },
        "processed_at": { "type": "string", "format": "date-time" },
        "materialized_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "$defs": {
    "span": {
      "type": "object",
      "additionalProperties": false,
      "required": ["page", "start_offset", "end_offset"],
      "properties": {
        "page": { "type": "integer", "minimum": 1 },
        "start_offset": { "type": "integer", "minimum": 0 },
        "end_offset": { "type": "integer", "minimum": 0 }
      }
    },
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_type", "artifact_id"],
      "properties": {
        "artifact_type": {
          "type": "string",
          "enum": ["ocr_span", "layout_block", "caption", "table", "figure", "page", "raw_text"]
        },
        "artifact_id": { "type": "string" },
        "page": {
          "type": ["integer", "null"],
          "minimum": 1
        }
      }
    },
    "pageSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["page", "summary"],
      "properties": {
        "page": { "type": "integer", "minimum": 1 },
        "summary": { "type": "string" },
        "embedding_ref": { "type": "string" }
      }
    },
    "chunk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chunk_id", "text", "span", "source_refs"],
      "properties": {
        "chunk_id": { "type": "string" },
        "text": { "type": "string" },
        "span": { "$ref": "#/$defs/span" },
        "embedding_ref": { "type": "string" },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceRef" },
          "minItems": 1
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean"]
          },
          "default": {}
        }
      }
    },
    "table": {
      "type": "object",
      "additionalProperties": false,
      "required": ["table_id", "page", "data", "source_refs"],
      "properties": {
        "table_id": { "type": "string" },
        "page": { "type": "integer", "minimum": 1 },
        "title": { "type": "string" },
        "summary_text": { "type": "string" },
        "embedding_ref": { "type": "string" },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceRef" },
          "minItems": 1
        },
        "data": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": ["string", "number", "boolean", "null"] }
          }
        }
      }
    },
    "figure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["figure_id", "page", "source_refs"],
      "properties": {
        "figure_id": { "type": "string" },
        "page": { "type": "integer", "minimum": 1 },
        "label": { "type": "string" },
        "image_ref": { "type": "string" },
        "description": { "type": "string" },
        "embedding_ref": { "type": "string" },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceRef" },
          "minItems": 1
        }
      }
    },
    "caption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["caption_id", "text", "source_refs"],
      "properties": {
        "caption_id": { "type": "string" },
        "figure_id": { "type": "string" },
        "text": { "type": "string" },
        "embedding_ref": { "type": "string" },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceRef" },
          "minItems": 1
        }
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_id", "label", "text"],
      "properties": {
        "entity_id": { "type": "string" },
        "label": { "type": "string" },
        "text": { "type": "string" },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
