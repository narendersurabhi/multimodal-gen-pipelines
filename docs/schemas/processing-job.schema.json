{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/processing-job.schema.json",
  "title": "Processing Job",
  "description": "Asynchronous processing lifecycle record for Phase 1 ingestion and extraction jobs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "job_id",
    "asset_id",
    "tenant_id",
    "status",
    "created_at",
    "updated_at",
    "attempt",
    "stages"
  ],
  "properties": {
    "job_id": {
      "type": "string",
      "pattern": "^job_[A-Za-z0-9]+$"
    },
    "asset_id": {
      "type": "string",
      "pattern": "^asset_[A-Za-z0-9]+$"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "succeeded",
        "partial_success",
        "failed",
        "cancelled"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "started_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "finished_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "failure_summary": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["code", "message", "retryable"],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "retryable": {
          "type": "boolean"
        }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "started_at", "warnings"],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "ingestion_validation",
              "normalization",
              "document_extraction",
              "vision_extraction",
              "text_chunking",
              "artifact_persistence"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["pending", "running", "succeeded", "failed", "skipped"]
          },
          "provider": {
            "type": ["string", "null"]
          },
          "started_at": {
            "type": ["string", "null"],
            "format": "date-time"
          },
          "finished_at": {
            "type": ["string", "null"],
            "format": "date-time"
          },
          "latency_ms": {
            "type": ["integer", "null"],
            "minimum": 0
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "error_code": {
            "type": ["string", "null"]
          },
          "retryable": {
            "type": ["boolean", "null"]
          }
        }
      }
    },
    "artifact_versions": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
