{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/grounded-summary.schema.json",
  "title": "Grounded Summary Output",
  "description": "Structured summary contract for retrieval-grounded multimodal generation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary_request_id",
    "request_id",
    "task_type",
    "asset_ids",
    "summary",
    "key_points",
    "citations",
    "confidence",
    "status"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "asset_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "key_points": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      },
      "default": []
    },
    "action_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      },
      "default": []
    },
    "citations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/citation"
      }
    },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overall",
        "grounding"
      ],
      "properties": {
        "overall": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "retrieval": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "generation": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "grounding": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "summary_request_id": {
      "type": "string"
    },
    "task_type": {
      "type": "string",
      "enum": [
        "grounded_summary",
        "question_answering",
        "risk_brief"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "succeeded",
        "partial_success",
        "abstained"
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "evidence_stats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_count"
      ],
      "properties": {
        "evidence_count": {
          "type": "integer",
          "minimum": 0
        },
        "citation_count": {
          "type": "integer",
          "minimum": 0
        },
        "modalities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "text",
              "document",
              "image",
              "table"
            ]
          },
          "default": []
        }
      }
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "detail"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "citation_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "citation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "citation_id",
        "asset_id",
        "evidence_type",
        "locator",
        "excerpt",
        "record_id"
      ],
      "properties": {
        "citation_id": {
          "type": "string"
        },
        "asset_id": {
          "type": "string"
        },
        "evidence_type": {
          "type": "string",
          "enum": [
            "chunk",
            "table",
            "figure",
            "caption",
            "page_summary"
          ]
        },
        "locator": {
          "type": "string",
          "description": "Human-readable page/chunk locator."
        },
        "excerpt": {
          "type": "string"
        },
        "record_id": {
          "type": "string"
        },
        "page_number": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
