{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/grounded-summary.schema.json",
  "title": "Grounded Summary Output",
  "description": "Structured summary contract for retrieval-grounded multimodal generation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "asset_ids",
    "summary",
    "key_points",
    "citations",
    "confidence"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "asset_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "key_points": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risks": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" },
      "default": []
    },
    "action_items": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" },
      "default": []
    },
    "citations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/citation" }
    },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overall"],
      "properties": {
        "overall": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "retrieval": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "generation": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "detail"],
      "properties": {
        "title": { "type": "string" },
        "detail": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "citation_ids": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "citation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["citation_id", "asset_id", "evidence_type", "locator", "excerpt"],
      "properties": {
        "citation_id": { "type": "string" },
        "asset_id": { "type": "string" },
        "evidence_type": {
          "type": "string",
          "enum": ["chunk", "table", "figure", "caption"]
        },
        "locator": {
          "type": "string",
          "description": "Human-readable page/chunk locator."
        },
        "excerpt": {
          "type": "string"
        }
      }
    }
  }
}
